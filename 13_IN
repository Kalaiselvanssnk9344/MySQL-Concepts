('XX', 99);

SELECT * FROM table1;

SELECT dept_name FROM table1
WHERE dept_name IN ('IT', 'CSE');

SELECT dept_name FROM table1
WHERE dept_name NOT IN ('IT', 'CSE');

CREATE TABLE table2 (
	emp_id INT PRIMARY KEY AUTO_INCREMENT,
    emp_name VARCHAR(200), 
    package DECIMAL(10, 2),
    dept_id INT,
    FOREIGN KEY (dept_id) REFERENCES table1(dept_id)
    
);


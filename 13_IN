
CREATE DATABASE practiceOne;

USE practiceOne;

CREATE TABLE table1 (
	dept_id INT PRIMARY KEY AUTO_INCREMENT,
    dept_name VARCHAR(200),
    salary DECIMAL(10, 2)
);

DROP TABLE table1;

TRUNCATE TABLE table1;

INSERT INTO table1 (dept_name, salary) VALUES

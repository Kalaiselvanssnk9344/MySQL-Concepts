SELECT dept_name FROM table1
WHERE dept_name LIKE 'c%';

SELECT dept_name FROM table1
WHERE dept_name LIKE '%sb%';

SELECT dept_name FROM table1
WHERE dept_name LIKE '_s%';

SELECT dept_name FROM table1
WHERE dept_name LIKE 'c__%';

SELECT dept_name FROM table1
WHERE dept_name LIKE 'a%s';

SELECT dept_name FROM table1
WHERE dept_name NOT LIKE 'c%';


